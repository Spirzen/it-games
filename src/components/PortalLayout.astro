---
import EcosystemNav from './EcosystemNav.astro';
import EcosystemFooter from './EcosystemFooter.astro';
import '../styles/tokens.css';
import '../styles/layout.css';
import '../styles/article.css';
import '../styles/article-chrome.css';
import '../styles/itu-loader.css';
import '../styles/games-intro.css';
import '../styles/games-platform-themes.css';

/** @typedef {{ id: string, label: string, href: string, active?: boolean }} NavItem */

interface Props {
  title: string;
  description?: string;
  brandLabel: string;
  brandHref: string;
  navItems: NavItem[];
  hasSidebar?: boolean;
  hasToc?: boolean;
  ecosystemConfigJson?: string;
  portalVariant?: 'default' | 'kids' | 'games';
  contentClass?: string;
}

const {
  title,
  description = '',
  brandLabel,
  brandHref,
  navItems,
  hasSidebar = false,
  hasToc = false,
  ecosystemConfigJson = '{}',
  portalVariant = 'default',
  contentClass = '',
} = Astro.props;
---

<!doctype html>
<html lang="ru" data-portal={portalVariant} data-platform={portalVariant === 'games' ? 'steam' : undefined}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <title>{title}</title>
    {description ? <meta name="description" content={description} /> : null}
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <script is:inline id="itu-ecosystem-config" type="application/json" set:html={ecosystemConfigJson} />
    <script is:inline define:vars={{portalVariant}}>
      (function () {
        try {
          var themeKey = 'itu-portal-theme';
          var platformKey = 'itu-games-platform';
          var platforms = ['steam', 'xbox', 'playstation', 'nintendo'];
          var root = document.documentElement;

          if (portalVariant === 'games') {
            var platform = localStorage.getItem(platformKey);
            root.dataset.platform = platforms.indexOf(platform) >= 0 ? platform : 'steam';
          }

          var stored = localStorage.getItem(themeKey);
          var theme =
            stored === 'light' || stored === 'dark'
              ? stored
              : portalVariant === 'games'
                ? 'dark'
                : window.matchMedia('(prefers-color-scheme: dark)').matches
                  ? 'dark'
                  : 'light';
          root.dataset.theme = theme;
          root.classList.toggle('dark', theme === 'dark');
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <EcosystemNav
      brandLabel={brandLabel}
      brandHref={brandHref}
      navItems={navItems}
      showPlatformPicker={portalVariant === 'games'}
    />
    <div class:list={['portal-shell', hasSidebar && 'has-sidebar', hasToc && 'has-toc']}>
      <slot name="sidebar" />
      <main class="portal-main" id="main-content">
        <div class:list={['portal-content', contentClass]}>
          <slot />
        </div>
      </main>
    </div>
    <EcosystemFooter />
    <script>
      import '../scripts/portal-client.js';
    </script>
  </body>
</html>
